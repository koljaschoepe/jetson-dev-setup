# =============================================================================
# Jetson Dev Setup — Kundenkonfiguration
# =============================================================================
# Kopiere diese Datei zu .env und passe die Werte an:
#   cp .env.example .env
#   nano .env
#
# Alle Variablen mit CHANGEME müssen angepasst werden.
# =============================================================================

# --- Kunden-Identifikation ---
CUSTOMER_NAME="CHANGEME"                  # z.B. "Firma-XY", "Projekt-Alpha"

# --- Jetson Benutzer ---
JETSON_USER="CHANGEME"                    # Benutzername auf dem Jetson (z.B. "arasul")
JETSON_HOSTNAME="jetson"                  # Hostname (erreichbar als <hostname>.local)

# --- NVMe SSD ---
NVME_DEVICE="/dev/nvme0n1"               # NVMe-Gerätepfad (normalerweise nicht ändern)
NVME_MOUNT="/mnt/nvme"                   # Mountpoint für NVMe
SWAP_SIZE="32G"                           # Swap-Größe (empfohlen: 16G-32G bei 8GB RAM)

# --- Netzwerk ---
INSTALL_TAILSCALE="false"                 # "true" für Remote-Zugriff außerhalb des LANs
STATIC_IP=""                              # Leer = DHCP, oder z.B. "192.168.1.100/24"
STATIC_GATEWAY=""                         # z.B. "192.168.1.1" (nur wenn STATIC_IP gesetzt)

# --- Git ---
GIT_USER_NAME="CHANGEME"                 # z.B. "Max Mustermann"
GIT_USER_EMAIL="CHANGEME"                # z.B. "max@firma.de"

# --- Entwicklungstools ---
NODE_VERSION="22"                         # Node.js LTS Version (22 empfohlen)
INSTALL_CLAUDE="true"                     # "true" für Claude Code Installation
INSTALL_OLLAMA="false"                    # "true" für lokale LLM-Inference

# --- Power Management ---
POWER_MODE="3"                            # 0=7W, 1=15W, 3=25W (empfohlen), MAXN=max

# --- Docker ---
DOCKER_LOG_MAX_SIZE="10m"                 # Max Größe pro Log-Datei
DOCKER_LOG_MAX_FILES="3"                  # Max Anzahl rotierter Log-Dateien
