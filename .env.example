# =============================================================================
# Arasul — Device Configuration
# =============================================================================
# Copy this file to .env and adjust values:
#   cp .env.example .env
#   nano .env
#
# All variables with CHANGEME must be updated.
# =============================================================================

# --- Device Identification ---
CUSTOMER_NAME="CHANGEME"                  # e.g. "my-company", "project-alpha"

# --- Jetson User ---
JETSON_USER="CHANGEME"                    # Username on the Jetson (e.g. "arasul")
JETSON_HOSTNAME="jetson"                  # Hostname (reachable as <hostname>.local)

# --- NVMe SSD ---
NVME_DEVICE="/dev/nvme0n1"               # NVMe device path (usually don't change)
NVME_MOUNT="/mnt/nvme"                   # NVMe mount point
SWAP_SIZE="32G"                           # Swap size (recommended: 16G-32G for 8GB RAM)

# --- Network ---
INSTALL_TAILSCALE="false"                 # "true" for remote access outside LAN
STATIC_IP=""                              # Empty = DHCP, or e.g. "192.168.1.100/24"
STATIC_GATEWAY=""                         # e.g. "192.168.1.1" (only when STATIC_IP is set)

# --- Git ---
GIT_USER_NAME="CHANGEME"                 # e.g. "John Doe"
GIT_USER_EMAIL="CHANGEME"                # e.g. "john@example.com"

# --- Development Tools ---
NODE_VERSION="22"                         # Node.js LTS version (22 recommended)
INSTALL_CLAUDE="true"                     # "true" to install Claude Code
INSTALL_OLLAMA="false"                    # "true" for local LLM inference
INSTALL_ARASUL_TUI="true"                # "true" for Arasul interactive TUI

# --- Power Management ---
POWER_MODE="3"                            # 0=7W, 1=15W, 3=25W (recommended), MAXN=max

# --- Docker ---
DOCKER_LOG_MAX_SIZE="10m"                 # Max size per log file
DOCKER_LOG_MAX_FILES="3"                  # Max number of rotated log files

# --- n8n Workflow Automation ---
INSTALL_N8N="false"                       # "true" to install n8n + PostgreSQL
